# OptionsOracle Reborn - Environment Variables Template
# Copy this file to '.env' and populate your credentials to enable live options feeds.

# Dhan API Credentials (get yours from https://dhan.co/api-access/)
DHAN_CLIENT_ID=your_dhan_client_id_here
DHAN_ACCESS_TOKEN=your_dhan_access_token_here

# Security Settings
JWT_SECRET=your_super_secret_jwt_key_random_alphanumeric_here

# Phone SMS OTP Configuration (Twilio)
# If left blank, the server will operate in Sandbox-Mock Mode:
# SMS is printed to backend console stdout, and you can bypass verification with code: 123456
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Telegram Bot Notifications
# Create a bot via BotFather to get a bot token, and query userinfobot for your Chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# WhatsApp Notifications (Twilio)
# Twilio sandbox WhatsApp sender. Default is "whatsapp:+14155238886"
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Gmail/Email SMTP Configuration
# Set SMTP_USER as your email address and SMTP_PASSWORD as your Gmail App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=



